# ============================================================
# Toolset Personal — Variables de Entorno (ejemplo)
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# Los secrets se gestionan via Infisical + GitHub Secrets.
# NO commitees este archivo con valores reales.
# ============================================================

# --- OpenCode Go (proveedor principal) ---
OPENCODE_GO_API_KEY=sk-

# --- Hermes (agente) ---
HERMES_LLM_PROVIDER=opencode-go
HERMES_LLM_MODEL=deepseek-v4-flash
HERMES_WEBUI_PASSWORD=
HERMES_WHATSAPP_MODE=

# --- Infisical (secret manager) ---
INFISICAL_ADMIN_EMAIL=admin@example.com
INFISICAL_ADMIN_PASSWORD=
INFISICAL_AUTH_SECRET=
INFISICAL_DB_PASSWORD=
INFISICAL_ENCRYPTION_KEY=
INFISICAL_SERVICE_TOKEN=

# --- Composio (MCP integrations) ---
COMPOSIO_API_KEY=
COMPOSIO_MCP_KEY=

# --- GitHub CLI (automation) ---
GH_CLI_TOKEN=

# --- OCI (infraestructura) ---
OCI_API_KEY=
OCI_DOMAIN_URL=
OCI_FINGERPRINT=
OCI_OAUTH_CLIENT_ID=
OCI_OAUTH_CLIENT_SECRET=
OCI_TENANCY_OCID=
OCI_USER_OCID=

# --- Tailscale (conectividad) ---
TAILSCALE_AUTH_KEY=

# --- SSH ---
SSH_PRIVATE_KEY=

# --- WhatsApp (gateway) ---
WHATSAPP_ALLOWED_USERS=
