# Toolset Personal — Caddy reverse proxy

{
    http_port 8080
    auto_https off
    admin off
    servers {
        timeouts {
            idle 0
        }
    }
}

:8080 {
    # Hindsight CP (Next.js SPA) — no auth
    handle /dashboard {
        reverse_proxy hindsight:9999
    }
    handle_path /dashboard/* {
        reverse_proxy hindsight:9999
    }
    handle /banks/* {
        reverse_proxy hindsight:9999
    }
    handle /bank/* {
        reverse_proxy hindsight:9999
    }
    handle /_next/* {
        reverse_proxy hindsight:9999
    }

    # CP API routes — no auth
    handle /api/version {
        reverse_proxy hindsight:9999
    }
    handle /api/banks/* {
        reverse_proxy hindsight:9999
    }
    handle /api/banks {
        reverse_proxy hindsight:9999
    }
    handle /api/profile/* {
        reverse_proxy hindsight:9999
    }
    handle /api/stats/* {
        reverse_proxy hindsight:9999
    }
    handle /api/list {
        reverse_proxy hindsight:9999
    }
    handle /api/recall {
        reverse_proxy hindsight:9999
    }
    handle /api/reflect {
        reverse_proxy hindsight:9999
    }
    handle /api/documents/* {
        reverse_proxy hindsight:9999
    }

    # Hindsight API — no auth, flush_interval -1 for SSE streaming
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888 {
            flush_interval -1
        }
    }

    # Swagger UI
    handle /openapi.json {
        reverse_proxy hindsight:8888
    }

    # Health endpoint
    handle /health {
        reverse_proxy hindsight:8888
    }

    # Hermes WebUI — has its own auth
    handle_path /hermes/* {
        reverse_proxy host.docker.internal:8877
    }

    # Infisical API — has its own auth
    handle /api/status {
        reverse_proxy infisical:8080
    }
    handle /api/v1/* {
        reverse_proxy infisical:8080
    }
    # Catch-all /api/* → CP
    handle /api/* {
        reverse_proxy hindsight:9999
    }

    # Root → landing page
    handle {
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
}
