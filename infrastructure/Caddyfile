# Toolset Personal — Caddy reverse proxy

{
    http_port 8080
    auto_https off
    admin off
}

:8080 {
    # Hindsight API (health, v1/*, docs, mcp, openapi.json, etc.)
    @hindsight path_regexp /hindsight/.+
    handle @hindsight {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888
    }

    # Hindsight Control Plane (served at /dashboard, redirects from legacy /cpanel)
    @cp path_regexp /dashboard(/.*)?
    handle @cp {
        reverse_proxy hindsight:9999
    }
    redir /cpanel{uri} /dashboard{uri} 301

    # Swagger UI needs openapi.json from Hindsight
    @openapi path /openapi.json
    handle @openapi {
        reverse_proxy hindsight:8888
    }

    # Service directory/landing page
    @status path_regexp /status(/.*)?
    handle @status {
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }

    # Everything else → Infisical (catch-all, SPA works natively at root)
    handle {
        reverse_proxy infisical:8080
    }
}
