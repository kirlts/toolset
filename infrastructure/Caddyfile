# Toolset Personal — Caddy reverse proxy
# FUNNEL_AUTH_USER and FUNNEL_AUTH_PASSWORD env vars set in docker-compose.yml

{
    http_port 8080
    auto_https off
    admin off
    servers {
        timeouts {
            idle 0
        }
    }
}

:8080 {
    # Hindsight Control Plane (Next.js SPA) — requires auth
    @cp_native path_regexp cp_native ^/(dashboard|_next)(/.*)?$
    handle @cp_native {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }

    # CP API routes — requires auth
    handle /api/version {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/banks/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/banks {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/profile/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/stats/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/list {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/recall {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/reflect {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /api/documents/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }

    # SPA fallback: /bank and /banks → requires auth
    handle /bank/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        handle /bank/api/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle /bank/_next/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle {
            reverse_proxy hindsight:9999
        }
    }
    handle /bank {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }
    handle /banks/* {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        handle /banks/api/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle /banks/_next/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle {
            reverse_proxy hindsight:9999
        }
    }
    handle /banks {
        basicauth * {
            {$FUNNEL_AUTH_USER} {$FUNNEL_AUTH_PASSWORD}
        }
        reverse_proxy hindsight:9999
    }

    # Hindsight API (health, v1/*, docs, mcp, openapi.json) — no auth required
    # flush_interval=0 disables response buffering needed for MCP Streamable HTTP + SSE
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888 {
            flush_interval 0
        }
    }

    # Swagger UI
    handle /openapi.json {
        reverse_proxy hindsight:8888
    }

    # Health endpoint — no auth required
    handle /health {
        reverse_proxy hindsight:8888
    }

    # Hermes WebUI — has its own auth
    handle_path /hermes/* {
        reverse_proxy host.docker.internal:8888
    }

    # Infisical API — has its own auth
    handle /api/status {
        reverse_proxy infisical:8080
    }
    handle /api/v1/* {
        reverse_proxy infisical:8080
    }
    # Catch-all /api/* → CP (protected by catch-all above)
    handle /api/* {
        reverse_proxy hindsight:9999
    }

    # Root → landing page — no auth
    handle {
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
}
