# Toolset Personal — Caddy reverse proxy

{
    http_port 8080
    auto_https off
    admin off
}

:8080 {
    # Hindsight Control Plane (Next.js SPA)
    @cp_native path_regexp cp_native ^/(dashboard|_next)(/.*)?$
    handle @cp_native {
        reverse_proxy hindsight:9999
    }
    # CP API routes
    handle /api/version {
        reverse_proxy hindsight:9999
    }
    handle /api/banks/* {
        reverse_proxy hindsight:9999
    }
    handle /api/banks {
        reverse_proxy hindsight:9999
    }

    # SPA fallback: /bank y /banks no tienen SSR en CP → servir shell de /dashboard
    handle /bank/* {
        handle /bank/api/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle /bank/_next/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle {
            rewrite * /dashboard
            reverse_proxy hindsight:9999
        }
    }
    handle /bank {
        rewrite * /dashboard
        reverse_proxy hindsight:9999
    }
    handle /banks/* {
        handle /banks/api/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle /banks/_next/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle {
            rewrite * /dashboard
            reverse_proxy hindsight:9999
        }
    }
    handle /banks {
        rewrite * /dashboard
        reverse_proxy hindsight:9999
    }

    # Hindsight API (health, v1/*, docs, mcp, openapi.json, etc.)
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888
    }

    # Swagger UI needs openapi.json from Hindsight
    handle /openapi.json {
        reverse_proxy hindsight:8888
    }

    # Health endpoint (always routes to Hindsight API, no Infisical dependency)
    handle /health {
        reverse_proxy hindsight:8888
    }

    # Infisical API (non-blocking — CP /api/banks/* and /api/version matched first)
    handle /api/* {
        reverse_proxy infisical:8080
    }

    # Service directory / status page (alias for landing page at root)
    handle /status/* {
        uri strip_prefix /status
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
    handle /status {
        redir /status/ 308
    }

    # Everything else — landing page (not Infisical catch-all)
    handle {
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
}
