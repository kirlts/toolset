# Toolset Personal — Caddy reverse proxy
# Generated by deploy.sh. Domain resolved from env: FUNNEL_DOMAIN

{
    http_port 8080
    auto_https off
    admin off
}

:8080 {
    # Hindsight API (incluye /health, /v1/*, /docs, /openapi.json, /mcp/, etc.)
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888
    }
    # Also match exact /hindsight (no trailing slash)
    handle /hindsight {
        redir /hindsight/ 301
    }

    # Hindsight Control Plane UI
    handle_path /cpanel/* {
        reverse_proxy hindsight:9999
    }

    # Redirect /dashboard -> /cpanel/ for discoverability
    redir /dashboard /cpanel/ 301

    # Future: Hermes MCP
    # handle_path /hermes-mcp/* {
    #     reverse_proxy hermes:XXXX
    # }

    # Future: Hermes web UI
    # handle_path /hermes/* {
    #     reverse_proxy hermes:XXXX
    # }

    # Everything else -> Infisical (SPA con assets root-relative)
    handle {
        reverse_proxy infisical:8080
    }
}
