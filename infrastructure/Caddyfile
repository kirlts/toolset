# Toolset Personal — Caddy reverse proxy

{
    http_port 8080
    auto_https off
    admin off
}

:8080 {
    # Hindsight Control Plane (Next.js SPA — /dashboard, /_next/*)
    @cp_native path_regexp cp_native ^/(dashboard|_next)(/.*)?$
    handle @cp_native {
        reverse_proxy hindsight:9999
    }

    # CP API routes (must come before Infisical /api/*)
    handle /api/version {
        reverse_proxy hindsight:9999
    }
    handle /api/banks/* {
        reverse_proxy hindsight:9999
    }
    handle /api/banks {
        reverse_proxy hindsight:9999
    }
    handle /api/profile/* {
        reverse_proxy hindsight:9999
    }
    handle /api/stats/* {
        reverse_proxy hindsight:9999
    }
    handle /api/list {
        reverse_proxy hindsight:9999
    }
    handle /api/recall {
        reverse_proxy hindsight:9999
    }
    handle /api/reflect {
        reverse_proxy hindsight:9999
    }
    handle /api/documents/* {
        reverse_proxy hindsight:9999
    }

    # SPA fallback: /bank y /banks → proxied directly to CP (no rewrite)
    handle /bank/* {
        handle /bank/api/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle /bank/_next/* {
            uri strip_prefix /bank
            reverse_proxy hindsight:9999
        }
        handle {
            reverse_proxy hindsight:9999
        }
    }
    handle /bank {
        reverse_proxy hindsight:9999
    }
    handle /banks/* {
        handle /banks/api/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle /banks/_next/* {
            uri strip_prefix /banks
            reverse_proxy hindsight:9999
        }
        handle {
            reverse_proxy hindsight:9999
        }
    }
    handle /banks {
        reverse_proxy hindsight:9999
    }

    # Hindsight API (health, v1/*, docs, mcp, openapi.json, etc.)
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888
    }

    # Swagger UI needs openapi.json from Hindsight
    handle /openapi.json {
        reverse_proxy hindsight:8888
    }

    # Health endpoint (always routes to Hindsight API, no Infisical dependency)
    handle /health {
        reverse_proxy hindsight:8888
    }

    # Infisical API (CP-specific routes matched first above)
    handle /api/status {
        reverse_proxy infisical:8080
    }
    handle /api/v1/* {
        reverse_proxy infisical:8080
    }
    # Catch-all /api/* — goes to CP (handles 404 gracefully, enables CP extensibility)
    handle /api/* {
        reverse_proxy hindsight:9999
    }

    # Landing page at /status/ (file server, always works)
    handle /status/* {
        uri strip_prefix /status
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
    handle /status {
        redir /status/ 308
    }

    # Root → landing page (not Infisical — avoids _next/* conflict with CP)
    handle {
        root * /usr/share/caddy/landing
        try_files {path} index.html
        file_server
    }
}
