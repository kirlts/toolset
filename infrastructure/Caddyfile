# Toolset Personal — Caddy reverse proxy

{
    http_port 8080
    auto_https off
    admin off
}

:8080 {
    # Hindsight API (health, v1/*, docs, mcp, openapi.json, etc.)
    handle /hindsight/* {
        uri strip_prefix /hindsight
        reverse_proxy hindsight:8888
    }

    # Hindsight API resources needed by Swagger UI (cargados desde la raiz)
    handle /openapi.json {
        reverse_proxy hindsight:8888
    }

    # Hindsight Control Plane UI
    handle /cpanel/* {
        reverse_proxy hindsight:9999
    }

    # Infisical (strippear prefix para que el SPA funcione en /)
    handle /infisical/* {
        uri strip_prefix /infisical
        reverse_proxy infisical:8080
    }

    # Landing page generada por deploy.sh
    @root expression `{http.request.uri.path} == '/'`
    handle @root {
        root * /usr/share/caddy/landing
        try_files index.html
        file_server
    }

    # Todo lo demas -> Infisical (catch-all para assets root-relative)
    handle {
        reverse_proxy infisical:8080
    }
}
