{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "bash": "allow",
    "external_directory": {
      "/workspace/*": "allow",
      "/tmp/*": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow"
  },
  "provider": {
    "opencodego": {
      "name": "OpenCode Go",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash"
        }
      }
    }
  },
  "mcp": {
    "composio": {
      "type": "remote",
      "url": "https://backend.composio.dev/tool_router/trs_MQn50-FzafCa/mcp",
      "headers": {
        "x-api-key": "{env:COMPOSIO_API_KEY}"
      }
    },
    "hindsight-selfhosted": {
      "type": "remote",
      "url": "https://toolset-oci-1-1.tail2d4c18.ts.net/hindsight/mcp/",
      "timeout": 120000
    }
  },
  "instructions": [
    "infrastructure/kilo-workflow.md",
    ".agents/rules/01-behavior.md",
    ".agents/rules/05-constraints.md",
    "docs/RULES.md"
  ],
  "model": "opencodego/deepseek-v4-flash",
  "agent": {
    "build": {
      "model": "opencodego/deepseek-v4-flash",
      "prompt": "Eres un agente de codigo efimero invocado por Hermes (el orquestador autonomo). Tu proposito es ejecutar una tarea especifica en un repositorio con autonomia total y reportar los resultados.

Las instrucciones base estan en los archivos listados en `instructions` en kilo.jsonc. Debes cargarlos y seguirlos. No los repitas, solo cumplelos.

Si el repositorio tiene `.agents/` -> sigue sus reglas. Es un proyecto gobernado.
Si NO tiene `.agents/` -> libre albedrio.

Respondes a Hermes con un resumen conciso: que se hizo, que cambio, resultados de tests, decisiones que necesitan aprobacion humana."
    }
  }
}
